{
  "name": "cogic",
  "publisher": "ppsssj",
  "displayName": "Cogic",
  "description": "Visualize code structure, calls, data flow, and framework routes inside VS Code.",
  "version": "0.0.1",
  "icon": "assets/logo.png",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "graph",
    "visualization",
    "typescript",
    "javascript",
    "react",
    "vue",
    "express",
    "nest"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ppsssj/CodeGraph.git"
  },
  "bugs": {
    "url": "https://github.com/ppsssj/CodeGraph/issues"
  },
  "homepage": "https://github.com/ppsssj/CodeGraph#readme",
  "galleryBanner": {
    "color": "#171717",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:codegraph.open",
    "onCommand:codegraph.openSidebar",
    "onView:codegraph.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codegraph",
          "title": "Cogic",
          "icon": "assets/logo.svg"
        }
      ]
    },
    "views": {
      "codegraph": [
        {
          "id": "codegraph.sidebar",
          "type": "webview",
          "name": "Cogic"
        }
      ]
    },
    "commands": [
      {
        "command": "codegraph.open",
        "title": "Cogic: Open Editor Panel"
      },
      {
        "command": "codegraph.openSidebar",
        "title": "Cogic: Focus Sidebar View"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build:all",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build:webview": "cd webview-ui && npm run build",
    "copy:webview": "node ./scripts/copy-webview.mjs",
    "build:all": "npm run build:webview && npm run copy:webview && npm run compile",
    "package:vsix": "npx @vscode/vsce package",
    "publish:marketplace": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  }
}
